rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Integrations subcollection:
      // - Client can READ to show connected/disconnected status (connectedAt, canvasUserName)
      // - Client CANNOT WRITE — only Vercel API routes via Admin SDK write tokens
      // - Firebase Admin SDK bypasses these rules entirely (used server-side)
      match /integrations/{integration} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
