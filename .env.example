# ============================================================
# ASCEND APP — Environment Variables
# Copy this file to .env.local for local development.
# Add all variables to Vercel project settings for production.
# ============================================================

# ---- Firebase Client SDK (safe to expose — public config) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- Firebase Admin SDK (SERVER-SIDE ONLY — never prefix with VITE_) ----
# Paste the entire service account JSON as a single-line string.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then run: cat your-service-account.json | jq -c . | pbcopy
FIREBASE_SERVICE_ACCOUNT_KEY=

# ---- Google Calendar OAuth (SERVER-SIDE ONLY) ----
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs must include: https://your-domain.vercel.app/api/auth/google/callback
# For local dev: http://localhost:3000/api/auth/google/callback (use 'vercel dev', not 'npm run dev')
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ascend-app-one.vercel.app/api/auth/google/callback

# ---- Microsoft/Outlook OAuth (SERVER-SIDE ONLY) ----
# Get from: Azure Portal → App registrations → your app → Certificates & secrets
# Authorized redirect URIs must include: https://your-domain.vercel.app/api/auth/microsoft/callback
# Tenant: use 'common' for personal + work accounts, or your tenant ID for org-only
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://ascend-app-one.vercel.app/api/auth/microsoft/callback
